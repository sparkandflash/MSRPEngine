# ╔══════════════════════════════════════════════════════════════════╗
# ║              Lyra — Environment Variable Reference              ║
# ║  Copy this file to .env and fill in your values.               ║
# ║  .env is loaded automatically at startup (if present).         ║
# ╚══════════════════════════════════════════════════════════════════╝

# ──────────────────────────────────────────────────────────────────
# SHARED DEFAULTS
# These are the fallback values used by all three agents (Responder,
# Reactor, Summariser) when their agent-specific overrides are not set.
# ──────────────────────────────────────────────────────────────────

# Backend type for the responder LLM.
# Options: openai | gemini | local-binary | embedded | mock
LYRA_RESPONDER_TYPE=openai

# API key for the responder LLM.
LYRA_API_KEY=

# Base URL of the OpenAI-compatible API endpoint (leave empty for official OpenAI).
# Examples:
#   https://api.cerebras.ai/v1
#   https://api.groq.com/openai/v1
#   http://localhost:11434/v1   (Ollama)
LYRA_BASE_URL=

# Model name to use for the responder.
# Examples: gpt-4o, llama3.1-70b, gemma-4-31b
LYRA_MODEL=

# Path to a local llama-cli binary (only required when LYRA_RESPONDER_TYPE=local-binary).
LYRA_LOCAL_BINARY_PATH=

# Override the responder system prompt (leave empty to use the built-in prompts/responder.txt).
LYRA_SYSTEM_INSTRUCTION=


# ──────────────────────────────────────────────────────────────────
# RESPONDER AGENT
# Controls the main conversational model (Lyra's voice).
# Falls back to the SHARED DEFAULTS above if not set.
# ──────────────────────────────────────────────────────────────────

# Short-term memory window for the responder (characters of recent conversation).
# Default: 2000
LYRA_RESPONDER_STM_CHARS=2000


# ──────────────────────────────────────────────────────────────────
# REACTOR AGENT
# Controls the mindstate analysis model.
# Falls back to the SHARED DEFAULTS above if not set.
# ──────────────────────────────────────────────────────────────────

# Backend type for the reactor LLM.
LYRA_REACTOR_TYPE=

# API key for the reactor LLM.
LYRA_REACTOR_API_KEY=

# Base URL of the reactor API endpoint.
LYRA_REACTOR_BASE_URL=

# Model name for the reactor (recommended: a small/fast model).
LYRA_REACTOR_MODEL=

# Path to a local llama-cli binary for the reactor (local-binary mode only).
LYRA_REACTOR_LOCAL_BINARY_PATH=

# Override the reactor system prompt (leave empty to use the built-in prompts/reactor.txt).
LYRA_REACTOR_SYSTEM_INSTRUCTION=

# Short-term memory window for the reactor (characters of conversation fed into mindstate analysis).
# Default: 2000
LYRA_MAX_WORKING_MEMORY_CHARS=2000


# ──────────────────────────────────────────────────────────────────
# SUMMARISER AGENT
# Controls the consolidation model used by >>consolidate.
# Falls back to the SHARED DEFAULTS above if not set.
# ──────────────────────────────────────────────────────────────────

# Backend type for the summariser LLM.
LYRA_SUMMARISER_TYPE=

# API key for the summariser LLM.
LYRA_SUMMARISER_API_KEY=

# Base URL of the summariser API endpoint.
LYRA_SUMMARISER_BASE_URL=

# Model name for the summariser.
LYRA_SUMMARISER_MODEL=

# Path to a local llama-cli binary for the summariser (local-binary mode only).
LYRA_SUMMARISER_LOCAL_BINARY_PATH=

# Override the summariser system prompt (leave empty to use the built-in prompts/consolidation.txt).
LYRA_SUMMARISER_SYSTEM_INSTRUCTION=


# ──────────────────────────────────────────────────────────────────
# EPISODE MEMORY
# Controls the runtime in-memory episode pool (episodic context
# injected into every responder call after >>consolidate is run).
# ──────────────────────────────────────────────────────────────────

# Total character budget for the active episode pool.
# When exceeded, the oldest non-pinned episode is evicted.
# Default: 2000
LYRA_EPISODE_MEMORY_CHARS=2000
